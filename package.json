{
  "name": "@mocito/raindrop-cli",
  "version": "0.2.2",
  "description": "Agent-friendly CLI for Raindrop.io",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvm/raindrop-cli.git"
  },
  "bin": {
    "raindrop": "dist/cli.js"
  },
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "skills/"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@11.0.6",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "pnpm codegen && tsup src/cli.ts --format esm --platform node --target node20 --out-dir dist --clean",
    "postbuild": "node scripts/ensure-bin-mode.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run",
    "smoke": "tsx test/smoke/live-smoke.ts",
    "codegen": "tsx scripts/codegen.ts",
    "spec-lint": "tsx scripts/spec-lint.ts",
    "verify-pack": "tsx scripts/verify-pack.ts",
    "skill:validate": "pnpm dlx skills-ref validate skills/raindrop-cli"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "smol-toml": "^1.4.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.0.3",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
